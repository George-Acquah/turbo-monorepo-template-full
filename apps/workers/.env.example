# =========================
# APP
# =========================
NODE_ENV=development
LOG_LEVEL=debug

# =========================
# SHARED INFRASTRUCTURE
# =========================
# Shared: canonical transactional store for api + workers.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/turbo_dev_pg

# Shared: Mongo document store for Mongo-owned concerns and projections
# such as notifications/search when those modules are enabled.
MONGODB_URI=mongodb://localhost:27017
MONGO_URI=mongodb://localhost:27017
MONGODB_DB_NAME=turbo_dev
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=1
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000

# Shared: object storage provider for api + workers.
STORAGE_PROVIDER=local
STORAGE_DEFAULT_BUCKET=uploads
STORAGE_PUBLIC_BASE_URL=
STORAGE_LOCAL_ROOT=.data/storage

# Shared: S3-compatible provider vars.
# Required for non-local providers. `STORAGE_S3_ENDPOINT` is optional for AWS S3,
# but required for R2/Supabase-style compatible endpoints.
STORAGE_S3_ENDPOINT=
STORAGE_S3_REGION=auto
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
STORAGE_S3_BUCKET=
STORAGE_S3_FORCE_PATH_STYLE=false

# =========================
# REDIS (shared infra)
# =========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379
REDIS_CONNECTION_TIMEOUT=5000
REDIS_TLS=false

# =========================
# WORKERS ONLY: observability
# =========================
ENABLE_LOKI=false
GRAFANA_ENV=local
GRAFANA_INSTANCE=local
GRAFANA_APP_NAME=template-workers
GRAFANA_APP_VERSION=0.0.1

GRAFANA_CLOUD_LOKI_URL=
GRAFANA_CLOUD_LOKI_USER=
GRAFANA_CLOUD_LOKI_PASSWORD=

GRAFANA_CLOUD_PROMETHEUS_URL=
GRAFANA_CLOUD_PROMETHEUS_USER=
GRAFANA_CLOUD_PROMETHEUS_PASSWORD=

GRAFANA_METRICS_USER=
GRAFANA_METRICS_PASSWORD=

LOCAL_LOKI_HOST=http://localhost:3100
