{
  "name": "@repo/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nest build",
    "check-types": "tsc --noEmit -p tsconfig.check.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@repo/config": "workspace:*",
    "@repo/context": "workspace:*",
    "@repo/core": "workspace:*",
    "@repo/events": "workspace:*",
    "@repo/filters": "workspace:*",
    "@repo/interceptor": "workspace:*",
    "@repo/observability": "workspace:*",
    "@repo/persistence": "workspace:*",
    "@repo/ports": "workspace:*",
    "@repo/queue": "workspace:*",
    "@repo/redis": "workspace:*",
    "@repo/storage": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "express": "^5.2.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.0",
    "@types/supertest": "^6.0.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsdown": "^0.20.3",
    "typescript": "^5.7.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@repo/constants$": "<rootDir>/../../../packages/server/constants/src/index.ts",
      "^@repo/config$": "<rootDir>/../../../packages/server/config/src/index.ts",
      "^@repo/context$": "<rootDir>/../../../packages/server/context/src/index.ts",
      "^@repo/decorators$": "<rootDir>/../../../packages/server/decorators/src/index.ts",
      "^@repo/events$": "<rootDir>/../../../packages/server/events/src/index.ts",
      "^@repo/filters$": "<rootDir>/../../../packages/server/filters/src/index.ts",
      "^@repo/interceptor$": "<rootDir>/../../../packages/server/interceptor/src/index.ts",
      "^@repo/persistence$": "<rootDir>/../../../packages/server/persistence/src/index.ts",
      "^@repo/ports$": "<rootDir>/../../../packages/server/ports/src/index.ts",
      "^@repo/queue$": "<rootDir>/../../../packages/server/queue/src/index.ts",
      "^@repo/redis$": "<rootDir>/../../../packages/server/redis/src/index.ts",
      "^@repo/storage$": "<rootDir>/../../../packages/server/storage/src/index.ts",
      "^@repo/types$": "<rootDir>/../../../packages/server/types/src/index.ts",
      "^@repo/types/express$": "<rootDir>/../../../packages/server/types/src/express.ts",
      "^@repo/utils$": "<rootDir>/../test-support/repo-utils.ts"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
