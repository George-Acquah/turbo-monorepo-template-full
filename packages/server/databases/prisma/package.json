{
  "name": "@repo/prisma",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "dependencies": {
    "@repo/types": "workspace:*",
    "@repo/ports": "workspace:*",
    "@repo/constants": "workspace:*",
    "@paralleldrive/cuid2": "^3.0.4",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "latest",
    "@prisma/client-runtime-utils": "7.0.0",
    "prisma": "latest"
  },
  "scripts": {
    "typecheck:prisma-config": "tsc -p tsconfig.prisma.json",
    "prisma:generate": "pnpm prisma generate --config ./prisma.config.ts && pnpm run generate:table-names",
    "prisma:reset": "pnpm prisma migrate reset",
    "prisma:migrate:dev": "pnpm prisma migrate dev --config ./prisma.config.ts",
    "migrate:deploy": "prisma migrate deploy --config=./prisma.config.ts",
    "generate:table-names": "node ./scripts/generate-table-names.mjs",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint src --ext .ts"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.1"
  },
  "devDependencies": {
    "dotenv": "^16.6.1",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^24.10.0",
    "ts-node": "^10.9.2",
    "tsdown": "^0.20.3"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  }
}
