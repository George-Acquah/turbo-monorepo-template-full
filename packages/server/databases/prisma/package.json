{
  "name": "@repo/database",
  "version": "0.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "private": true,
  "dependencies": {
    "@repo/types": "workspace:*",
    "@repo/ports": "workspace:*",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "latest",
    "@prisma/client-runtime-utils": "7.0.0",
    "prisma": "latest"
  },
  "scripts": {
    "prisma:generate": "pnpm prisma generate --config ./prisma.config.ts && pnpm run generate:table-names",
    "prisma:migrate:dev": "pnpm prisma migrate dev --schema ./prisma/schema/schema.prisma --config ./prisma.config.ts",
    "migrate:deploy": "prisma migrate deploy --config=./prisma.config.ts",
    "build": "tsc -p tsconfig.json",
    "generate:table-names": "node ./scripts/generate-table-names.mjs"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.1"
  },
  "devDependencies": {
    "dotenv": "^16.6.1",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^24.10.0",
    "tsdown": "^0.20.3"
  }
}
