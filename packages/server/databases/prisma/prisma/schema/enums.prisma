// packages/database/prisma/schema/enums.prisma
// Shared enums across all bounded contexts

// ─────────────────────────────────────────────────────────────────────────────
// User & Auth Enums
// ─────────────────────────────────────────────────────────────────────────────
enum UserRole {
    CUSTOMER
    ADMIN
    SUPER_ADMIN

    @@schema("users")
}

enum UserStatus {
    ACTIVE
    INACTIVE
    SUSPENDED
    PENDING_VERIFICATION

    @@schema("users")
}

enum AuthProvider {
    EMAIL
    GOOGLE
    GITHUB
    APPLE
    PHONE

    @@schema("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// Payment Enums
// ─────────────────────────────────────────────────────────────────────────────
enum PaymentStatus {
    PENDING
    INITIATED
    PROCESSING
    PAID
    FAILED
    CANCELLED
    REFUNDED
    PARTIALLY_REFUNDED
    EXPIRED

    @@schema("payments")
}

enum PaymentProvider {
    PAYSTACK
    FLUTTERWAVE
    MOBILE_MONEY
    BANK_TRANSFER
    CASH

    @@schema("payments")
}

enum PaymentMethod {
    CARD
    MOBILE_MONEY
    BANK_TRANSFER
    USSD
    QR_CODE
    CASH

    @@schema("payments")
}

enum RefundStatus {
    PENDING
    PROCESSING
    COMPLETED
    FAILED
    REJECTED

    @@schema("payments")
}

enum WebhookEventStatus {
    PENDING
    PROCESSING
    PROCESSED
    FAILED
    SKIPPED

    @@schema("payments")
}

// ─────────────────────────────────────────────────────────────────────────────
// File Enums
// ─────────────────────────────────────────────────────────────────────────────
enum FileType {
    IMAGE
    DOCUMENT
    VIDEO
    AUDIO
    OTHER

    @@schema("files")
}

enum FileBucket {
    PRODUCT_IMAGES
    COLLECTION_ASSETS
    REVIEW_IMAGES
    USER_AVATARS
    INVOICES
    RECEIPTS
    GENERAL

    @@schema("files")
}

enum FileVisibility {
    PUBLIC
    PRIVATE
    SIGNED

    @@schema("files")
}
