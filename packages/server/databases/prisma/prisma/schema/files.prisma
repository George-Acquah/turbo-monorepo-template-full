// ─────────────────────────────────────────────────────────────────────────────
// BatchImage - Junction table for Batch-File relationship
// ─────────────────────────────────────────────────────────────────────────────
model BatchImage {
  id      String @id
  batchId String @map("batch_id")
  fileId  String @map("file_id")

  // Image role
  isBanner  Boolean @default(false) @map("is_banner")
  sortOrder Int     @default(0) @map("sort_order")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([batchId, fileId])
  @@index([batchId])
  @@index([fileId])
  @@map("batch_images")
  @@schema("files")
}
