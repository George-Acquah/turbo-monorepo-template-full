// packages/database/prisma/schema/notifications.prisma
// Notifications Bounded Context - Multi-channel notifications and templates

// ─────────────────────────────────────────────────────────────────────────────
// NotificationTemplate - Reusable notification templates
// ─────────────────────────────────────────────────────────────────────────────
model NotificationTemplate {
  id String @id

  // Template identification
  name String @unique
  slug String @unique
  //This will be enforced at the application layer
  type String

  // Channel-specific content
  channels NotificationChannel[]

  // Email template
  emailSubject String? @map("email_subject")
  emailHtml    String? @map("email_html")
  emailText    String? @map("email_text")

  // SMS template
  smsBody String? @map("sms_body")

  // Push notification template
  pushTitle String? @map("push_title")
  pushBody  String? @map("push_body")
  pushData  Json?   @map("push_data") @db.JsonB

  // In-app notification
  inAppTitle  String? @map("in_app_title")
  inAppBody   String? @map("in_app_body")
  inAppAction String? @map("in_app_action") // Action URL or deep link

  // Slack template
  slackMessage Json? @map("slack_message") @db.JsonB // Slack block kit

  // Telegram template
  telegramMessage String? @map("telegram_message")

  // WhatsApp template
  whatsappTemplateId String? @map("whatsapp_template_id")
  whatsappParams     Json?   @map("whatsapp_params") @db.JsonB

  // Variables (for validation)
  variables String[] // e.g., ["orderNumber", "customerName"]

  // Status
  isActive Boolean @default(true) @map("is_active")

  // Metadata
  description String?
  metadata    Json?   @db.JsonB

  // Timestamps
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@index([type])
  @@index([isActive])
  @@map("notification_templates")
  @@schema("notifications")
}

// ─────────────────────────────────────────────────────────────────────────────
// Notification - Individual notification instances
// ─────────────────────────────────────────────────────────────────────────────
model Notification {
  id String @id

  // Type and channel
  type    String
  channel NotificationChannel

  // Template reference
  templateId String? @map("template_id")

  // Recipient info
  userId            String? @map("user_id")
  recipientEmail    String? @map("recipient_email")
  recipientPhone    String? @map("recipient_phone")
  recipientDevice   String? @map("recipient_device") // Push token
  recipientSlack    String? @map("recipient_slack") // Slack channel/user
  recipientTelegram String? @map("recipient_telegram") // Chat ID

  // Content
  subject  String?
  title    String?
  body     String
  htmlBody String? @map("html_body")
  data     Json?   @db.JsonB // Additional data

  // Related entities (cross-schema references)
  orderId   String? @map("order_id")
  batchId   String? @map("batch_id")
  paymentId String? @map("payment_id")

  // Status
  status NotificationStatus @default(PENDING)

  // Scheduling
  scheduledAt DateTime? @map("scheduled_at") @db.Timestamptz(6)

  // Delivery tracking
  queuedAt    DateTime? @map("queued_at") @db.Timestamptz(6)
  sentAt      DateTime? @map("sent_at") @db.Timestamptz(6)
  deliveredAt DateTime? @map("delivered_at") @db.Timestamptz(6)
  openedAt    DateTime? @map("opened_at") @db.Timestamptz(6)
  clickedAt   DateTime? @map("clicked_at") @db.Timestamptz(6)
  failedAt    DateTime? @map("failed_at") @db.Timestamptz(6)

  // Retry info
  retryCount  Int       @default(0) @map("retry_count")
  maxRetries  Int       @default(3) @map("max_retries")
  nextRetryAt DateTime? @map("next_retry_at") @db.Timestamptz(6)

  // Failure info
  failureCode    String? @map("failure_code")
  failureMessage String? @map("failure_message")

  // Provider info
  providerId       String? @map("provider_id") // Provider's message ID
  providerResponse Json?   @map("provider_response") @db.JsonB

  // Metadata
  metadata Json? @db.JsonB

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  logs NotificationLog[]

  @@index([userId])
  @@index([type, channel])
  @@index([status])
  @@index([scheduledAt])
  @@index([orderId])
  @@index([batchId])
  @@index([createdAt])
  @@map("notifications")
  @@schema("notifications")
}

// ─────────────────────────────────────────────────────────────────────────────
// NotificationLog - Log of notification delivery attempts
// ─────────────────────────────────────────────────────────────────────────────
model NotificationLog {
  id             String       @id
  notificationId String       @map("notification_id")
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  // Attempt info
  attemptNumber Int                @map("attempt_number")
  status        NotificationStatus

  // Provider info
  providerId       String? @map("provider_id")
  providerResponse Json?   @map("provider_response") @db.JsonB

  // Failure info
  failureCode    String? @map("failure_code")
  failureMessage String? @map("failure_message")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([notificationId])
  @@index([createdAt])
  @@map("notification_logs")
  @@schema("notifications")
}

// ─────────────────────────────────────────────────────────────────────────────
// InAppNotification - In-app notification for user notification center
// ─────────────────────────────────────────────────────────────────────────────
model InAppNotification {
  id String @id

  // Recipient
  userId String @map("user_id")

  // Content
  type      String
  title     String
  body      String
  actionUrl String? @map("action_url")
  imageUrl  String? @map("image_url")

  // Related entities
  orderId String? @map("order_id")
  batchId String? @map("batch_id")

  // Status
  isRead      Boolean   @default(false) @map("is_read")
  readAt      DateTime? @map("read_at") @db.Timestamptz(6)
  isDismissed Boolean   @default(false) @map("is_dismissed")
  dismissedAt DateTime? @map("dismissed_at") @db.Timestamptz(6)

  // Expiry
  expiresAt DateTime? @map("expires_at") @db.Timestamptz(6)

  // Metadata
  metadata Json? @db.JsonB

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
  @@index([expiresAt])
  @@map("in_app_notifications")
  @@schema("notifications")
}

// ─────────────────────────────────────────────────────────────────────────────
// PushDevice - Registered push notification devices
// ─────────────────────────────────────────────────────────────────────────────
model PushDevice {
  id String @id

  // User reference
  userId String @map("user_id")

  // Device info
  token       String  @unique // Push token
  platform    String // "ios", "android", "web"
  deviceId    String? @map("device_id")
  deviceModel String? @map("device_model")
  osVersion   String? @map("os_version")
  appVersion  String? @map("app_version")

  // Status
  isActive Boolean @default(true) @map("is_active")

  // Last activity
  lastActiveAt DateTime? @map("last_active_at") @db.Timestamptz(6)

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)


  @@map("push_devices")
  @@schema("notifications")
}

// ─────────────────────────────────────────────────────────────────────────────
// NotificationConfig - Channel configuration
// ─────────────────────────────────────────────────────────────────────────────
model NotificationConfig {
  id String @id

  channel NotificationChannel @unique

  // Provider configuration (encrypted in practice)
  provider  String // e.g., "sendgrid", "twilio", "firebase"
  apiKey    String? @map("api_key")
  apiSecret String? @map("api_secret")

  // Channel-specific config
  fromEmail        String? @map("from_email")
  fromName         String? @map("from_name")
  fromPhone        String? @map("from_phone")
  slackWebhook     String? @map("slack_webhook")
  telegramBotToken String? @map("telegram_bot_token")

  // Rate limiting
  rateLimit  Int? @map("rate_limit") // Per minute
  dailyLimit Int? @map("daily_limit")

  // Status
  isActive Boolean @default(true) @map("is_active")

  // Metadata
  metadata Json? @db.JsonB

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("notification_configs")
  @@schema("notifications")
}
