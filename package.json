{
  "name": "template",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:api": "turbo run build --filter=@repo/api",
    "build:workers": "turbo run build --filter=@repo/workers",
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=@repo/api",
    "dev:workers": "turbo run dev --filter=@repo/workers",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.10",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22"
  }
}
